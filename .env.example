NODE_ENV=development
PORT=4010
MRI_CASE_STORE_MODE=sqlite
# MRI_CASE_STORE_FILE=./.mri-data/cases.sqlite
MRI_CASE_STORE_DATABASE_URL=
MRI_CASE_STORE_SCHEMA=public

# Legacy/adjacent Postgres seam used by earlier baseline tooling.
# DATABASE_URL=

# ── Internal-route authentication ─────────────────────
# HMAC-SHA256 signed requests (recommended for production).
# Secret MUST be ≥ 32 bytes. When set, every /api/internal/dispatch/*
# route requires X-MRI-Timestamp, X-MRI-Nonce, and X-MRI-Signature headers.
# MRI_INTERNAL_HMAC_SECRET=

# Maximum clock skew allowed for HMAC timestamps (milliseconds).
# Default: 60000 (60 seconds).
# MRI_CLOCK_SKEW_TOLERANCE_MS=60000

# Bearer-token auth for all /api/internal/* routes (independent of HMAC).
# MRI_INTERNAL_API_TOKEN=

# Clinician identity source for public review/finalize actions.
# Current supported value: request-body
# MRI_REVIEWER_IDENTITY_SOURCE=request-body

# ── Replay-nonce protection ───────────────────────────
# TTL for nonce entries in milliseconds. Default: 120000 (2× clock-skew window).
# MRI_REPLAY_STORE_TTL_MS=120000

# Maximum in-memory nonce entries (memory mode safety cap). Default: 10000.
# MRI_REPLAY_STORE_MAX_ENTRIES=10000

# ── Public-edge hardening ─────────────────────────────
# Maximum JSON body size accepted by the API.
# MRI_JSON_BODY_LIMIT=1mb

# Public API rate-limit window and quota.
# MRI_PUBLIC_RATE_LIMIT_WINDOW_MS=900000
# MRI_PUBLIC_RATE_LIMIT_MAX_REQUESTS=300

# HTTP server timeout hardening.
# MRI_SERVER_HEADERS_TIMEOUT_MS=30000
# MRI_SERVER_REQUEST_TIMEOUT_MS=120000
# MRI_SERVER_SOCKET_TIMEOUT_MS=120000
# MRI_SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
# MRI_SERVER_MAX_REQUESTS_PER_SOCKET=100

# Maximum graceful shutdown wait before force-closing open HTTP connections.
# MRI_GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000

# ── Derived artifact storage seam ─────────────────────
# Storage provider for typed derived-artifact references.
# Supported values: local-file, s3-compatible
# MRI_ARTIFACT_STORE_PROVIDER=local-file

# Base path used for local-file artifact URIs and as the object-key prefix
# for s3-compatible deployments. Defaults to ./.mri-data/artifacts.
# MRI_ARTIFACT_STORE_BASE_PATH=./.mri-data/artifacts

# Optional explicit endpoint for s3-compatible artifact storage.
# Example: https://minio.example.local
# MRI_ARTIFACT_STORE_ENDPOINT=

# Optional bucket name for s3-compatible artifact storage.
# MRI_ARTIFACT_STORE_BUCKET=

# ── Dispatch queue substrate ──────────────────────────
# Queue provider for internal dispatch/claim.
# Supported values: local, redis
# MRI_QUEUE_PROVIDER=local

# Redis connection string when MRI_QUEUE_PROVIDER=redis.
# MRI_REDIS_URL=redis://127.0.0.1:6379

# Queue key prefix for stage-specific dispatch lists.
# MRI_QUEUE_KEY_PREFIX=mri-second-opinion:queue
