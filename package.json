{
  "name": "mri-second-opinion",
  "version": "0.1.0",
  "private": true,
  "description": "Clinician-in-the-loop MRI second-opinion workflow baseline with a standalone TypeScript API and restart-safe local persistence",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/KonkovaElena/mri-second-opinion.git"
  },
  "bugs": {
    "url": "https://github.com/KonkovaElena/mri-second-opinion/issues"
  },
  "keywords": [
    "mri",
    "medical-imaging",
    "radiology",
    "second-opinion",
    "clinical-review",
    "typescript",
    "nodejs",
    "express",
    "workflow-orchestration",
    "research-use-only"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate:smoke": "tsx scripts/db-migrate-smoke.ts",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "verify:postgres-bootstrap": "tsx scripts/verify-postgres-bootstrap.ts",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "pg-mem": "^3.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
